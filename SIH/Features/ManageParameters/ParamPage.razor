@page "/parameters"
@using System.Text.Json

<div class="d-flex flex-row mh-100 gap-1" style="min-height: 0; flex: 1; margin-bottom: 5px;">
    <aside class="d-flex flex-column overflow-auto mh-100 my-secondary-bg rounded-start-2" style="max-width: 350px; min-width: 350px; flex: 1; scrollbar-gutter: stable; margin-left: 5px;">
        <div class="accordion accordion-flush" id="accordionExample">

            @for (int i = 0; i < ParameterCategoryArr.Length; i++)
            {
                <div class="accordion-item">
                    <h2 class="accordion-header">
                        <button class="accordion-button collapsed shadow-none p-3" type="button" data-bs-toggle="collapse" data-bs-target="#collapse_@i" aria-expanded="true" aria-controls="collapse_@i">
                            @ParameterCategoryArr[i]
                        </button>
                    </h2>
                    <div id="collapse_@i" class="accordion-collapse collapse">
                        <div class="accordion-body p-2">
                            <ul class="d-flex flex-column p-0 m-0" style="list-style-type: none;">
                                <li class="active">fShadowDistance</li>
                                <li>iNumFocusShadow</li>
                                <li>fInteriorShadowDistance</li>
                                <li>ffocusShadowMapDoubleEveryXUnit</li>
                                <li>iShadowMapResolution</li>
                                <li>fDynamicDOFBlurMultiplier</li>
                                <li>fProjectedUVNormalDetailTilingScale</li>
                                <li>fProjectedUVDiffuseNormalTilingScale</li>
                                <li>bEnableProjecteUVDiffuseNormals</li>
                                <li>bUseTAA</li>
                                <li>bIndEnable</li>
                                <li>bSAO_CS_Enable</li>
                                <li>bToggleSparkles</li>
                                <li>bSAOEnable</li>
                                <li>bScreenSpaceReflectionEnabled</li>                            
                            </ul>
                        </div>
                    </div>
                </div>
            }

        </div>
    </aside>
    <main class="d-flex flex-column my-secondary-bg rounded-end-2 overflow-hidden" style="flex: 1; margin-right: 5px;">
        <div id="header" class="d-flex flex-row align-items-center border-bottom" style="margin-left: 4px; margin-right: 4px; padding-bottom: 2px;">
            <i class="bi bi-arrow-left" style="font-size: 2rem; color: white;"></i>
            <div class="flex-grow-1" style="margin-left: 5px;">
                fShadowDistance - Дистанция теней
            </div>
            <i class="bi bi-arrow-right" style="font-size: 2rem; color: white;"></i>
        </div>
        <div id="paramData" class="d-flex flex-row overflow-auto" style="flex: 1;">           
            <div id="paramData-desc" class="card m-1 p-1 justify-content-between" style="width: min-content; font-size: 15px;">
                Параметр fShadowDistance задает расстояние, на котором тени отбрасываются от игрока.
                Увеличение этого параметра приводит к снижению разрешения теней, поскольку карта
                теней растягивается на это расстояние. Это можно компенсировать увеличением параметра
                iShadowMapResolution.
                <br><br>Чтобы избежать заметных переходов теней, рекомендуется устанавливать значение 4000 или выше.

                <div id="footer" class="d-flex flex-column align-items-start p-1 gap-1 border-top" style="padding-bottom: 2px; width: min-content;">
                    <div class="d-flex flex-row text-center align-items-center pb-1 gap-1" style="width: stretch;">
                        <div>Значение: </div>
                        <InputNumber TValue="int" @bind-Value=@ParamValue class="" style="flex:1;" />
                    </div>
                   
                    <div class="d-flex flex-row align-items-center gap-1">
                        <div class="btn btn-success"> ПРИМЕНИТЬ</div>
                        <div class="btn btn-danger"> ВОССТАНОВИТЬ</div>
                    </div>

                </div>
            </div>
                                      
            <div id="paramData-screen" class="p-1" style="flex: 1; overflow-x:hidden; width: min-content;">
                <div class="row row-cols-1 row-cols-md-2 g-3">
                    <div class="col">
                        <div class="card h-100">
                            <img src="/images/FShadowDistance=2800.jpg" class="card-img-top" alt="...">
                            <div class="card-body">
                                <h6 class="card-title">fShadowDistance=4000</h6>
                                <p class="card-text"></p>
                            </div>
                        </div>
                    </div>
                    <div class="col">
                        <div class="card h-100">
                            <img src="/images/FShadowDistance=2800.jpg" class="card-img-top" alt="...">
                            <div class="card-body">
                                <h6 class="card-title">fShadowDistance=0</h6>
                                <p class="card-text"></p>
                            </div>
                        </div>
                    </div>
                    <div class="col">
                        <div class="card h-100">
                            <img src="/images/FShadowDistance=2800.jpg" class="card-img-top" alt="...">
                            <div class="card-body">
                                    <h6 class="card-title">fShadowDistance=2000</h6>
                                <p class="card-text"></p>
                            </div>
                        </div>
                    </div>
                    <div class="col">
                        <div class="card h-100">
                            <img src="/images/FShadowDistance=2800.jpg" class="card-img-top" alt="...">
                            <div class="card-body">
                                <h6 class="card-title">fShadowDistance=-2000</h6>
                                <p class="card-text"></p>
                            </div>
                        </div>
                    </div>
                    <div class="col">
                        <div class="card h-100">
                            <img src="/images/FShadowDistance=2800.jpg" class="card-img-top" alt="...">
                            <div class="card-body">
                                <h6 class="card-title">fShadowDistance=-2000</h6>
                                <p class="card-text"></p>
                            </div>
                        </div>
                    </div>
                    <div class="col">
                        <div class="card h-100">
                            <img src="/images/FShadowDistance=2800.jpg" class="card-img-top" alt="...">
                            <div class="card-body">
                                <h6 class="card-title">fShadowDistance=-2000</h6>
                                <p class="card-text"></p>
                            </div>
                        </div>
                    </div>
                    <div class="col">
                        <div class="card h-100">
                            <img src="/images/FShadowDistance=2800.jpg" class="card-img-top" alt="...">
                            <div class="card-body">
                                <h6 class="card-title">fShadowDistance=-2000</h6>
                                <p class="card-text"></p>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
        
    </main>
    
</div>

@code {
    private int ParamValue;

    private string[] ParameterCategoryArr = { 
        "[Display]",
        "[General]",
        "[MAIN]",
        "[Interface]",
        "[GamePlay]",
        "[Controls]",
        "[Particles]",
        "[SaveGame]",
        "[AudioMenu]",
        "[Clouds]",
        "[Water]",
        "[TerrainManager]",
        "[NavMesh]",
        "[Trees]",
        "[Grass]",
        "[Decals]",
        "[LOD]",
        "[Launcher]",
        "[Bethesda.net]"
    };

    private string[] MyParameterCategoryArr = {
        "[Display]",

    };

    protected override async Task OnInitializedAsync()
    {
        var stream = await FileSystem.OpenAppPackageFileAsync("Resources/Data/ini_values_info.json");

        using var reader = new StreamReader(stream);
        var json = await reader.ReadToEndAsync();

        var paramList = JsonSerializer.Deserialize<List<Parameter>>(json)!;

        foreach (var param in paramList)
        {
            param.Load("C:\\Games\\SkyrimRP\\profiles\\SkyrimRP");
        }
    }
}
